# --- Database (Prisma 7 + MySQL via the mariadb driver adapter) ---
# allowPublicKeyRetrieval=true lets the mariadb driver complete MySQL 8's
# caching_sha2_password RSA handshake over non-TLS connections. Without it,
# connections fail with ER_CANNOT_RETRIEVE_RSA_KEY after a MySQL restart
# clears the server-side auth cache. For TLS connections this isn't needed.
DATABASE_URL="mysql://root:password@localhost:3306/finance?allowPublicKeyRetrieval=true"

# --- Auth ---
JWT_SECRET="change-me-in-prod"
JWT_EXPIRES="7d"

# --- Server ---
PORT=3000
# Interface to bind. Dev: 0.0.0.0 (default). Production behind nginx: 127.0.0.1
# so the API is only reachable through the reverse proxy.
HOST=0.0.0.0
# CORS allowlist. Leave UNSET for same-origin nginx deploys or local dev
# (reflects any origin). For split frontend/backend origins, set a
# comma-separated list, e.g. CORS_ORIGIN=https://app.example.com
# CORS_ORIGIN=
