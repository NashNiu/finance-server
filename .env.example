# --- Database (Prisma 7 + PostgreSQL via @prisma/adapter-pg) ---
# Local dev: a local Postgres, e.g.
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance"
# Supabase: use the "Session pooler" connection string from
#   Project Settings -> Database -> Connection string -> URI (port 5432).
# Use sslmode=no-verify (SSL on, skip strict cert verification). Newer pg treats
# sslmode=require as verify-full, which fails the pooler cert -> TlsConnectionError.
# URL-encode special chars in the password (% -> %25, @ -> %40, etc.).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance"

# --- Auth ---
JWT_SECRET="change-me-in-prod"
JWT_EXPIRES="7d"

# --- Server ---
# PORT is provided by the host (Render) at runtime; defaults to 3000 locally.
PORT=3000
# Bind interface. Leave 0.0.0.0 for Render/containers. (127.0.0.1 only when
# fronted by a local reverse proxy on the same host.)
HOST=0.0.0.0
# CORS allowlist. Leave UNSET when the frontend reaches the API same-origin
# (e.g. via a Vercel rewrite). For a split origin, set a comma-separated list,
# e.g. CORS_ORIGIN=https://your-app.vercel.app
# CORS_ORIGIN=
