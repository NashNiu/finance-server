# Production backend config. Copy to `.env` on the server and fill in real values.

# Point at the production MySQL. Use a dedicated DB user, NOT root.
DATABASE_URL="mysql://finance_user:STRONG_PASSWORD@localhost:3306/finance"

# Use a long random secret (e.g. `openssl rand -hex 32`).
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
JWT_EXPIRES="7d"

PORT=3000
# Behind the nginx reverse proxy on the same host — listen on localhost only.
HOST=127.0.0.1

# Same-origin deploy (nginx serves frontend and proxies /api), so CORS is not
# triggered and can stay unset. If you ever serve the frontend from a different
# origin, set the allowlist here.
# CORS_ORIGIN=https://your-domain.com
